# Copy to server/.env (recommended) or server/src/.env — both are loaded;
# server/.env wins over server/src/.env and repo root .env on duplicate keys.
#
# Starburst Galaxy (Trino over HTTPS)
# STARBURST_SERVER = cluster Trino host from Partner connect → Trino JDBC (NOT the main Galaxy UI domain).
# Either https://account-cluster.trino.galaxy.starburst.io or paste the full jdbc:trino://host:443?... URL.
STARBURST_SERVER=https://YOUR_ACCOUNT-YOUR_CLUSTER.trino.galaxy.starburst.io
# Same user string as Partner connect / JDBC (role after /). Prefer no quotes around values.
STARBURST_USER=your.email@example.com/accountadmin
# Galaxy profile password (Profile → Change password). Required for JDBC/REST even if you log in with SSO.
STARBURST_PASSWORD=your-password-or-app-password
STARBURST_CATALOG=your_catalog
STARBURST_SCHEMA=your_schema
# Optional: limit information_schema metadata to one table
STARBURST_TABLE=kaggle_tx_data

# S3 inventory (same data lake backing the Galaxy catalog)
# Required for local dev unless ~/.aws/credentials exists or the process uses an IAM role.
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
S3_BUCKET=your-bucket
# Optional key prefix
S3_PREFIX=

# OpenAI (or compatible) Chat Completions — required for measured prompt + completion tokens
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# GPT-5 / o-series use max_completion_tokens automatically; for odd gateways: OPENAI_USE_MAX_COMPLETION_TOKENS=1

# Caps / tuning
MAX_METADATA_ROWS=800
MAX_S3_OBJECTS=2500
PORT=8787
